# EA APEX PHP site (Vercel or custom domain). No trailing slash.
EXPO_PUBLIC_APEX_ORIGIN=https://ea-apex.vercel.app

# This app’s own API base (e.g. Bun/Render URL) for routes under /api/*
EXPO_PUBLIC_API_BASE_URL=

# Optional: comma-separated legacy hosts whose /terminal/ws URLs are rewritten
# when proxying broker HTML (Bun server only).
# LEGACY_TERMINAL_WS_HOSTS=
